PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@smart-mentor-connect.scndnyb.mongodb.net/?appName=Smart-Mentor-Connect
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=30d
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# In production, set this to your Render backend URL:
# GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/calendar/callback
